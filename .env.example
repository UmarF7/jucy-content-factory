# JUCY CLEANSE — API Configuration
# Copy this to .env and fill in your API keys

# Higgsfield (AI Video Generation)
HIGGSFIELD_API_KEY=your_higgsfield_api_key_here

# OpenAI (Script Generation & Analysis)
OPENAI_API_KEY=sk-your-openai-key-here

# TikTok (Publishing)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_BUSINESS_ACCOUNT_ID=your_tiktok_business_account_id

# Instagram (Publishing)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# YouTube (Publishing)
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# Database (Analytics)
DATABASE_URL=your_database_connection_string
DATABASE_TYPE=sqlite # or postgresql

# Webhook (Optional - for notifications)
WEBHOOK_URL=https://your-webhook-endpoint.com/notify
SLACK_WEBHOOK=https://hooks.slack.com/services/your/webhook/url
